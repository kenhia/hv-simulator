  "demographics": {
    "canon": true,
    "total_population": 3600000000,
    "as_of_pd": 1922,
    "source": "HH12, Companion",
    "notes": "~3.6 billion as of early 1922 PD, spread across the three habitable planets and the main asteroid belt; majority in the Manticore-A subsystem."
  },
  "lore": {
    "summary": "The Manticore System is the binary home system of the Star Kingdom of Manticore, 512 light-years galactic-north of Sol. It is unusual for holding three habitable worlds (Manticore, Sphinx, Gryphon) and for hosting the Manticore Wormhole Junction, one of the largest known, which made the small star nation one of the wealthiest in human space.",
    "naming_convention": "All planets are named after creatures from Earth mythology.",
    "timeline": [
      {
        "pd": 562,
        "event": "Sir Frederick Clarke confirms the existence of planets in the system.",
        "source": "Companion"
      },
      {
        "pd": 753,
        "event": "Franchot et Fils' survey ship Suffren makes the first voyage to Manticore; three habitable planets and resource-rich asteroid belts confirmed.",
        "source": "UHH"
      },
      {
        "pd": 775,
